{
  "$description": "OneBrain is an AI Design System — cross-platform design tokens in W3C DTCG format. This file is the single machine-readable source of truth; tokens/build.js generates the per-platform outputs in tokens/dist/ (CSS vars, JS/TS, Tailwind preset, iOS Swift, Android XML). Dark-first: the canonical $value is the dark/near-black operator-console value; the light/spec override lives in $extensions['com.onebrain.light']. Every value traces to onebrain-ai/website src/styles/global.css — see PROVENANCE.md. Do not invent values outside this file; derive with oklch()/color-mix().",

  "color": {
    "$type": "color",
    "$description": "Surfaces, text, and the four neon signal accents. rgba primitives are stored as #RRGGBBAA. Light overrides re-ink the accents for the white ground (AA >=4.5:1 on #fff).",

    "bg":        { "$value": "#050507", "$description": "App canvas (near-black operator ground)", "$extensions": { "com.onebrain.light": "#f4f4f7" } },
    "bgDeep":    { "$value": "#020204", "$description": "Sticky-nav base (rgba(2,2,4,.92))",        "$extensions": { "com.onebrain.light": "#ffffff" } },
    "surface":   { "$value": "#0a0a12", "$description": "Raised panel / surface",                   "$extensions": { "com.onebrain.light": "#ffffff" } },
    "surface2":  { "$value": "#08080e", "$description": "Card fill (rgba(8,8,14,.78))",             "$extensions": { "com.onebrain.light": "#fafafe" } },
    "border":    { "$value": "#ffffff14", "$description": "Hairline border (rgba(255,255,255,.08))","$extensions": { "com.onebrain.light": "#0808102e" } },
    "border2":   { "$value": "#ffffff0f", "$description": "Card hairline (rgba(255,255,255,.06))",  "$extensions": { "com.onebrain.light": "#08081014" } },
    "text":      { "$value": "#f0f0f2", "$description": "Primary text",                              "$extensions": { "com.onebrain.light": "#0a0a12" } },
    "muted":     { "$value": "#a1a1aa", "$description": "Secondary / muted text",                   "$extensions": { "com.onebrain.light": "#52525b" } },
    "faint":     { "$value": "#ffffff9e", "$description": "Sub-paragraph / mono body (.62)",        "$extensions": { "com.onebrain.light": "#0a0a1299" } },
    "ghost":     { "$value": "#ffffff2e", "$description": "Tiny meta labels (.18)",                 "$extensions": { "com.onebrain.light": "#0a0a1259" } },
    "white":     { "$value": "#ffffff", "$description": "Headlines + brand emphasis",               "$extensions": { "com.onebrain.light": "#0a0a12" } },

    "accent":   { "$value": "#bc13fe", "$description": "Neon violet — primary / gradient start / button frame", "$extensions": { "com.onebrain.light": "#9500c7" } },
    "accent2":  { "$value": "#00f3ff", "$description": "Electric cyan — default section accent / focus ring",    "$extensions": { "com.onebrain.light": "#007a90" } },
    "accent3":  { "$value": "#ff2d92", "$description": "Hot magenta — brand glow / status dot / CTA glow",       "$extensions": { "com.onebrain.light": "#c2186a" } },
    "accent4":  { "$value": "#ffb000", "$description": "Amber — warnings / occasional highlight",               "$extensions": { "com.onebrain.light": "#9a6400" } },

    "vault":    { "$value": "#7c3aed", "$description": "Obsidian vault hub core/spokes (diagrams)" },
    "vault2":   { "$value": "#a78bfa", "$description": "Obsidian vault hub light" },
    "harness":  { "$value": "#00cce0", "$description": "Harness layer gradient top (diagrams)" },
    "harness2": { "$value": "#00646e", "$description": "Harness layer gradient bottom" },
    "loop":     { "$value": "#a8d000", "$description": "Co-evolution loop nodes (diagrams)" },
    "loop2":    { "$value": "#d4ff45", "$description": "Co-evolution loop light" }
  },

  "state": {
    "$type": "color",
    "$description": "Semantic state colors. success is its own re-inked value; info/warning/danger alias the accents so they inherit light re-inking automatically.",
    "success": { "$value": "#a8d000", "$description": "lime", "$extensions": { "com.onebrain.light": "#5f7d00" } },
    "info":    { "$value": "{color.accent2}", "$description": "cyan" },
    "warning": { "$value": "{color.accent4}", "$description": "amber" },
    "danger":  { "$value": "{color.accent3}", "$description": "magenta" }
  },

  "chart": {
    "$type": "color",
    "$description": "Data-viz palette. Categorical series c1–c6 alias the accents/diagram colors so they inherit light re-inking; grid/axis/track stay low-contrast (the data is the signal, not the chrome). Use 1–3 series typically; the full 6 only for genuinely categorical data.",
    "c1":    { "$value": "{color.accent2}", "$description": "cyan / teal — primary series" },
    "c2":    { "$value": "{color.accent}",  "$description": "violet / orchid" },
    "c3":    { "$value": "{color.accent3}", "$description": "magenta / rose" },
    "c4":    { "$value": "{color.accent4}", "$description": "amber / ochre" },
    "c5":    { "$value": "{state.success}", "$description": "lime / moss" },
    "c6":    { "$value": "{color.vault2}",  "$description": "vault light purple", "$extensions": { "com.onebrain.light": "#6d28d9" } },
    "grid":  { "$value": "#ffffff0f", "$description": "low-contrast gridline",       "$extensions": { "com.onebrain.light": "#08081012" } },
    "axis":  { "$value": "{color.muted}", "$description": "axis labels / ticks" },
    "track": { "$value": "#ffffff0d", "$description": "bar track / sequential base", "$extensions": { "com.onebrain.light": "#0808100d" } }
  },

  "intent": {
    "$type": "color",
    "$description": "Alias / intent layer. Components reference THESE, never raw palette hexes — re-skin a surface by remapping intents. Each resolves to a primitive above (and inherits its light override).",
    "textPrimary":   { "$value": "{color.text}" },
    "textSecondary": { "$value": "{color.muted}" },
    "textTertiary":  { "$value": "{color.faint}" },
    "textDisabled":  { "$value": "{color.ghost}" },
    "textOnAccent":  { "$value": "{color.bg}", "$description": "dark ink reads on a filled neon accent" },
    "textLink":      { "$value": "{intent.actionPrimary}", "$description": "inline links — follow the action accent" },
    "textLinkHover": { "$value": "{color.white}" },
    "bgBase":        { "$value": "{color.bg}" },
    "bgSurface":     { "$value": "{color.surface}" },
    "bgElevated":    { "$value": "{color.surface2}" },
    "bgSunken":      { "$value": "{color.bgDeep}" },
    "borderDefault": { "$value": "{color.border}" },
    "borderSubtle":  { "$value": "{color.border2}" },
    "borderStrong":  { "$value": "#f0f0f23d", "$description": "stronger border for interactive controls = color-mix(text 24%); concrete equivalent for native/Tailwind export", "$extensions": { "com.onebrain.light": "#0a0a123d" } },
    "borderFocus":   { "$value": "{color.accent2}" },
    "actionPrimary": { "$value": "{color.accent2}", "$description": "default = cyan; override per region" },
    "actionSecondary": { "$value": "{color.accent}" },
    "focusRing":     { "$value": "{color.accent2}" }
  },

  "gradient": {
    "$description": "Brand gradients (CSS gradient strings — web only). brand lifted from brain.svg; button from .btn-tech.",
    "brand":  { "$value": "linear-gradient(135deg, #ff2d92 0%, #ff5aa3 55%, #00f3ff 100%)" },
    "button": { "$value": "linear-gradient(135deg, #bc13fe, #00f3ff)" }
  },

  "font": {
    "family": {
      "$type": "fontFamily",
      "sans":    { "$value": ["Inter", "ui-sans-serif", "system-ui", "-apple-system", "BlinkMacSystemFont", "Segoe UI", "sans-serif"], "$description": "Body sans (system/Google fallback — not shipped as a file)" },
      "mono":    { "$value": ["JetBrains Mono", "ui-monospace", "SF Mono", "Menlo", "Consolas", "monospace"], "$description": "Eyebrows, metadata, code, IDs, dense-console body" },
      "display": { "$value": ["Chakra Petch", "Inter", "ui-sans-serif", "system-ui", "sans-serif"], "$description": "Display — italic + uppercase headlines / wordmark" }
    },
    "weight": {
      "$type": "fontWeight",
      "light":    { "$value": 300 },
      "regular":  { "$value": 400 },
      "medium":   { "$value": 500 },
      "semibold": { "$value": 600 },
      "bold":     { "$value": 700 }
    },
    "size": {
      "$type": "dimension",
      "$description": "px = base16 * rem. h2/hero carry a static native fallback in $value and the responsive web clamp() in $extensions.web.",
      "eyebrow": { "$value": "10px", "$description": "pill / kicker" },
      "xs":      { "$value": "11px", "$description": "card description, fine print" },
      "sm":      { "$value": "13px", "$description": "mono metadata" },
      "base":    { "$value": "16px", "$description": "body" },
      "md":      { "$value": "17px", "$description": "card title" },
      "lg":      { "$value": "20px", "$description": "lead" },
      "xl":      { "$value": "24px", "$description": "subsection" },
      "xxl":     { "$value": "32px", "$description": "large stat" },
      "h2":      { "$value": "56px", "$description": "section headline", "$extensions": { "web": "clamp(2.4rem, 5.6vw, 5rem)" } },
      "hero":    { "$value": "72px", "$description": "hero display",     "$extensions": { "web": "clamp(3rem, 9vw, 8rem)" } }
    },
    "leading": {
      "$type": "number",
      "tight": { "$value": 0.95, "$description": "display" },
      "snug":  { "$value": 1.2 },
      "body":  { "$value": 1.5 },
      "prose": { "$value": 1.65, "$description": "mono sub-paragraphs" }
    },
    "tracking": {
      "$description": "Letter-spacing in em (web-native unit).",
      "tight":   { "$value": "-0.02em", "$description": "display headlines" },
      "normal":  { "$value": "0" },
      "wide":    { "$value": "0.04em", "$description": "card titles" },
      "label":   { "$value": "0.3em", "$description": "small uppercase labels" },
      "eyebrow": { "$value": "0.4em", "$description": "pills / status lines" }
    }
  },

  "space": {
    "$type": "dimension",
    "$description": "4px base scale (matches --space-1…9). Comfortable-dense.",
    "0": { "$value": "0px" },
    "1": { "$value": "4px" },
    "2": { "$value": "8px" },
    "3": { "$value": "12px" },
    "4": { "$value": "16px" },
    "5": { "$value": "24px", "$description": "card padding x, section padding x" },
    "6": { "$value": "32px" },
    "7": { "$value": "40px", "$description": "section padding y (mobile)" },
    "8": { "$value": "64px", "$description": "section padding (desktop), nav height" },
    "9": { "$value": "96px" }
  },

  "size": {
    "$type": "dimension",
    "controlH":   { "$value": "44px", "$description": "min touch target / control height (comfortable)" },
    "controlHSm": { "$value": "36px" },
    "navHeight":  { "$value": "64px", "$description": "nav height / scroll-padding-top" },
    "contentMax": { "$value": "1280px", "$description": "content shell max-width" },
    "proseMax":   { "$value": "640px",  "$description": "prose / sub max-width" },
    "gridSize":   { "$value": "56px",   "$description": "HUD lattice cell" }
  },

  "breakpoint": {
    "$type": "dimension",
    "$description": "Layout breakpoints (px). Reference values for JS/native responsive logic and documentation — CSS @media cannot read custom properties, so author media queries with these literals. The one canonical scale every surface shares.",
    "sm":    { "$value": "360px",  "$description": "mobile compact" },
    "md":    { "$value": "600px",  "$description": "large phone / foldable" },
    "lg":    { "$value": "768px",  "$description": "tablet portrait" },
    "xl":    { "$value": "1024px", "$description": "tablet landscape / small laptop — console multi-col threshold" },
    "xxl":   { "$value": "1280px", "$description": "laptop / content shell" },
    "wide":  { "$value": "1440px", "$description": "desktop" },
    "ultra": { "$value": "1920px", "$description": "wide" }
  },

  "radius": {
    "$type": "dimension",
    "$description": "Deliberately sharp — corners are cut, not rounded. Default 0.",
    "0":    { "$value": "0px",   "$description": "panels / cards (default)" },
    "xs":   { "$value": "2px",   "$description": "inline code, tiny chips" },
    "sm":   { "$value": "4px",   "$description": "small controls" },
    "pill": { "$value": "999px", "$description": "nav counter, status dots only" }
  },

  "clipPath": {
    "$description": "Angled 'tech' corner cut used by .btn-tech / framed CTAs instead of any radius (web only). FIXED-size corners (clip.cut px), NOT percentages, so the cut stays an even, tasteful size at ANY button width — percentage cuts balloon into huge diagonal wedges on wide buttons.",
    "cut":  { "$value": "12px", "$description": "corner-cut size — fixed so wide buttons keep an even hairline frame" },
    "tech": { "$value": "polygon(12px 0, 100% 0, 100% calc(100% - 12px), calc(100% - 12px) 100%, 0 100%, 0 12px)" }
  },

  "shadow": {
    "$description": "This system has almost no soft drop-shadow; elevation reads as neon glow. The light theme remaps elev-* to real drop-shadows. Values are CSS box-shadow / drop-shadow strings.",
    "glowCta":       { "$value": "0 0 14px rgba(255,45,146,.5)", "$description": "btn-tech hover" },
    "glowCyan":      { "$value": "0 0 22px rgba(0,243,255,.55)" },
    "shadowOverlay": { "$value": "0 24px 60px rgba(0,0,0,.55)", "$description": "dropdowns / modals — the only true shadow" },
    "elev1": { "$value": "0 0 0 1px rgba(255,255,255,.08)",                              "$extensions": { "com.onebrain.light": "0 1px 2px rgba(10,10,18,.06), 0 0 0 1px rgba(8,8,16,.12)" } },
    "elev2": { "$value": "0 0 0 1px rgba(255,255,255,.08), 0 18px 40px rgba(0,0,0,.45)", "$extensions": { "com.onebrain.light": "0 4px 14px rgba(10,10,18,.10), 0 0 0 1px rgba(8,8,16,.12)" } },
    "elev3": { "$value": "0 0 0 1px rgba(255,255,255,.08), 0 24px 60px rgba(0,0,0,.55)", "$extensions": { "com.onebrain.light": "0 18px 44px rgba(10,10,18,.16), 0 0 0 1px rgba(8,8,16,.12)" } }
  },

  "motion": {
    "duration": {
      "$type": "duration",
      "fast":   { "$value": "200ms" },
      "base":   { "$value": "250ms" },
      "slow":   { "$value": "450ms" },
      "reveal": { "$value": "1200ms" }
    },
    "easing": {
      "$type": "cubicBezier",
      "outExpo": { "$value": [0.16, 1, 0.3, 1],   "$description": ".reveal" },
      "boot":    { "$value": [0.22, 1, 0.36, 1],  "$description": "section entry" },
      "drain":   { "$value": [0.55, 0, 0.45, 1],  "$description": "headline color drain" }
    }
  },

  "opacity": {
    "$type": "number",
    "disabled": { "$value": 0.42, "$description": "disabled affordance (0.38–0.5 per Material)" }
  },

  "zIndex": {
    "$type": "number",
    "bg":      { "$value": -1 },
    "grid":    { "$value": 1 },
    "content": { "$value": 10 },
    "spine":   { "$value": 30 },
    "warp":    { "$value": 45 },
    "nav":     { "$value": 50 },
    "counter": { "$value": 1000 }
  }
}
