# --- OS / editor junk ---
.DS_Store
**/.DS_Store
Thumbs.db
*.swp

# --- Uploaded reference media (not part of the design-system package) ---
# Stock synthwave imagery + feedback screenshots used during iteration.
# Excluded to keep the repo lean; the package does not reference these.
uploads/

# --- Local verification artifacts (regenerated on demand) ---
*.screenshot.png
.playwright/

# --- Open Design host machinery (not part of the portable package) ---
.od-skills/
*.artifact.json
# OD design-system registry metadata (display name / status / local revisions) —
# local-only; the portable package is defined by DESIGN.md + tokens, not this.
metadata.json
revisions/

# --- Stray reference / marked-up screenshots dropped at project root (not referenced) ---
mpt*-*.jpg
mpt*-*.png
mpt*-*.jpeg
# OD preview-comment screenshots use a rolling timestamp prefix (mpt*, mpu*, …)
*-drawing-*.png
*-drawing-*.jpg
*-drawing-*.jpeg
# Attached reference frames dropped at root as mp<id>-image.<ext>
mp*-image.png
mp*-image.jpg
mp*-image.jpeg

# --- GitHub connector intake evidence (raw snapshots of already-public source) ---
# Re-pullable; kept LOCAL to satisfy the Open Design publish gate ("connector
# evidence"), but out of the repo so it stays lean (the GitHub repo was pruned of
# context/ post-build). Restore both repos with the bounded intake:
#   "$OD_NODE_BIN" "$OD_BIN" tools connectors github-design-context \
#     --repo 'https://github.com/onebrain-ai/website'  --output context/github/onebrain-ai-website.md
#   "$OD_NODE_BIN" "$OD_BIN" tools connectors github-design-context \
#     --repo 'https://github.com/onebrain-ai/onebrain' --output context/github/onebrain-ai-onebrain.md
context/
